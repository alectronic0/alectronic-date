<section id="moments">
  <div class="container">
    <div class="section-tag tag-gold">🏆 Notable Moments</div>
    <h2>A Life Well Lived (So Far)</h2>
    <div class="moments-grid">
      <div class="moment"><span class="moment-icon">🎓</span> Got a 1st @ University</div>
