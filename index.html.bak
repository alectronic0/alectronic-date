<!-- ════════════════ HERO ════════════════ -->
<header class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-emoji">🎮❤️🎮</div>
      <h1>Alec's <span>Dating</span> Application</h1>
      <p class="hero-sub">A visual introduction to what having me as your boyfriend could look like.</p>
      <p class="hero-tagline">Loveable nerd, looking for his player 2. No swiping required.</p>
      <a href="#about" class="hero-cta">Come find out more ↓</a>
    </div>
    <div class="hero-media">
      <img src="img/coverphoto/index.png" alt="Alec Doran-Twyford">
      <img src="img/alec/PXL_20251128_071312852.PORTRAIT.jpg" alt="Alec smiling">
      <img src="img/alec/PXL_20260514_052228361.PORTRAIT.jpg" alt="Alec portrait">
    </div>
  </div>
  <div class="hero-scroll">scroll to explore ↓</div>
</header>

