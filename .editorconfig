[*.{js,jsx,ts,tsx}]
# Allow lines to be as wide as needed
max_line_length = 100000

# Force array items to split down into one-per-line structure
ij_javascript_array_initializer_wrap = split_into_lines
ij_javascript_array_initializer_new_line_after_left_brace = true
ij_javascript_array_initializer_right_brace_on_new_line = true

# Keep the small inner object blocks completely flat on a single line
ij_javascript_object_literal_wrap = off
ij_javascript_keep_simple_blocks_in_one_line = true
ij_javascript_keep_multiple_expressions_in_one_line = true

# Mirror the exact same rules for TypeScript files
ij_typescript_array_initializer_wrap = split_into_lines
ij_typescript_array_initializer_new_line_after_left_brace = true
ij_typescript_array_initializer_right_brace_on_new_line = true
ij_typescript_object_literal_wrap = off
ij_typescript_keep_simple_blocks_in_one_line = true
ij_typescript_keep_multiple_expressions_in_one_line = true
